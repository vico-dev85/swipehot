# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Chaturbate API
CB_API_URL=https://chaturbate.com/api/public/affiliates/onlinerooms/
CB_API_TOKEN=your_chaturbate_api_token_here

# White label domain (embeds + CTAs go through this, not chaturbate.com)
WHITELABEL_DOMAIN=www.xcam.vip

# Redis
REDIS_URL=redis://localhost:6379

# Affiliate config
AFFILIATE_CAMPAIGN=roGHG
AFFILIATE_TOUR=9oGW
AFFILIATE_TRACK=wetroulette

# Pool refresh interval (cron expression — every 60 seconds)
POOL_REFRESH_CRON=*/60 * * * * *

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=xcamvip
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=xcamvip
MYSQL_POOL_SIZE=10

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
